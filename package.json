{
  "name": "luminotype",
  "version": "0.1.0",
  "private": true,
  "description": "A fast, minimalist typing test web app",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"pnpm --filter @luminotype/api dev\" \"pnpm --filter @luminotype/web dev\"",
    "build": "pnpm --filter @luminotype/shared build && pnpm --filter @luminotype/api build && pnpm --filter @luminotype/web build",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "pnpm -r --if-present test"
  },
  "dependencies": {
    "@luminotype/api": "workspace:*",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}
