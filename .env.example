# PostgreSQL credentials (used by the db service and the api connection string)
POSTGRES_USER=luminotype
POSTGRES_PASSWORD=luminotype
POSTGRES_DB=luminotype

# Connection string the api uses. Host "db" is the compose service name.
DATABASE_URL=postgres://luminotype:luminotype@db:5432/luminotype

# Host port the web app is published on (maps to nginx :80 in the web container).
WEB_PORT=8080
